## Hola Suite Dashboard — Variables de entorno
##
## Copia este archivo a `.env` y completa los valores.
## Nota: para evitar exponer secretos en Git, usa `.env` o `data/global_config.local.json`.

# Server
PORT=3000
HOST=127.0.0.1

# Auth
JWT_SECRET=change_me

# ClickUp
CLICKUP_API_KEY=
CLICKUP_LIST_ID=

# Hola Suite API (Wispro)
HOLA_API_URL=https://wispro.holasuite.com/api/v1
HOLA_API_TOKEN=

# Google Sheets (si aplica)
GOOGLE_SHEETS_API_KEY=

