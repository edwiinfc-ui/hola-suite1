# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# URL del proyecto Supabase
# Obtener de: Settings → API → Project URL
SUPABASE_URL=https://vvrnufzwyxszknnnfvig.supabase.co

# Anon Public Key para el cliente
# Obtener de: Settings → API → Project API keys → anon (public)
SUPABASE_ANON_KEY=

# Service Role Secret para operaciones del servidor
# Obtener de: Settings → API → Project API keys → service_role (secret)
SUPABASE_SERVICE_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# JWT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# JWT Secret para autenticación local
JWT_SECRET=tu_jwt_secret_super_seguro_aqui

# ═══════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Puerto donde corre el servidor
PORT=3000

# Ambiente (development, production)
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════
# CLICKUP CONFIGURATION (Opcional)
# ═══════════════════════════════════════════════════════════════════════════

CLICKUP_API_KEY=tu_clickup_api_key
CLICKUP_LIST_ID=tu_clickup_list_id

# ═══════════════════════════════════════════════════════════════════════════
# HOLA SUITE / OPA CONFIGURATION (Opcional)
# ═══════════════════════════════════════════════════════════════════════════

# Base URL ejemplo: https://wispro.holasuite.com
HOLA_API_URL=

# Token JWT/Bearer provisto por ¡Hola! Suite (NO lo hardcodees en frontend)
HOLA_API_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# GOOGLE SHEETS CONFIGURATION (Opcional)
# ═══════════════════════════════════════════════════════════════════════════

GOOGLE_SHEETS_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

FRONTEND_URL=http://localhost:3000
